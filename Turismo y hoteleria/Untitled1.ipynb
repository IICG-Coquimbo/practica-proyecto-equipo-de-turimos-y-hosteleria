    "import time\n",
    "import re\n",
    "from datetime import datetime\n",
    "from pymongo import MongoClient\n",
    "import certifi\n",
    "from selenium import webdriver\n",
    "from selenium.webdriver.chrome.service import Service\n",
    "from selenium.webdriver.chrome.options import Options\n",
    "from selenium.webdriver.common.by import By\n",
    "\n",
    "\n",
    "def limpiar_precio(texto):\n",
    "    \"\"\"Extrae solo números del texto del precio y lo convierte a float.\"\"\"\n",
    "    numeros = ''.join(c for c in texto if c.isdigit())\n",
    "    if not numeros:\n",
    "        return 0.0\n",
    "    precio = float(numeros)\n",
    "    if precio < 5000 or precio > 10000000:\n",
    "        return 0.0\n",
    "    return precio\n",
    "\n",
    "\n",
    "def determinar_zona(ciudad):\n",
    "    \"\"\"Clasifica la ciudad en una zona geográfica de Chile.\"\"\"\n",
    "    if ciudad in ['Arica', 'Iquique', 'Calama', 'Antofagasta']:\n",
    "        return 'Norte Grande'\n",
    "    elif ciudad in ['Copiapo', 'La Serena']:\n",
    "        return 'Norte Chico'\n",
    "    elif ciudad in ['Valparaiso', 'Vina del Mar', 'Santiago', 'Rancagua']:\n",
    "        return 'Centro'\n",
    "    elif ciudad in ['Talca', 'Chillan', 'Concepcion', 'Temuco']:\n",
    "        return 'Centro Sur'\n",
    "    elif ciudad in ['Valdivia', 'Puerto Varas', 'Puerto Montt']:\n",
    "        return 'Los Lagos'\n",
    "    else:\n",
    "        return 'Patagonia'\n",
    "\n",
    "\n",
    "def ejecutar_extraccion():\n",
    "    \"\"\"\n",
    "    Función principal que ejecuta el scraping de Google Hotels\n",
    "    para 10 ciudades de Chile y guarda en MongoDB Atlas.\n",
    "   \n",
    "    Retorna:\n",
    "        list: Lista de diccionarios con los datos extraídos.\n",
    "    \"\"\"\n",
    "    datos_finales = []\n",
    "\n",
    "    # ========== CONEXIÓN A MONGODB ATLAS ==========\n",
    "    uri = \"mongodb+srv://lucascheuque_db_user:27032005@cluster0.tjvu2a3.mongodb.net/?retryWrites=true&w=majority\"\n",
    "    client = MongoClient(uri, tlsCAFile=certifi.where(), serverSelectionTimeoutMS=5000)\n",
    "    db = client['proyecto_bigdata']\n",
    "    coleccion = db['google_hotels']\n",
    "    print(\"✅ Conexión exitosa a MongoDB Atlas\")\n",
    "\n",
    "    # ========== CONFIGURACIÓN DEL NAVEGADOR ==========\n",
    "    options = Options()\n",
    "    options.binary_location = \"/usr/bin/google-chrome\"\n",
    "    options.add_argument(\"--no-sandbox\")\n",
    "    options.add_argument(\"--disable-dev-shm-usage\")\n",
    "    options.add_argument(\"--window-size=1920,1080\")\n",
    "    options.add_argument(\"--disable-blink-features=AutomationControlled\")\n",
    "\n",
    "    service = Service(\"/usr/bin/chromedriver\")\n",
    "    driver = webdriver.Chrome(service=service, options=options)\n",
    "\n",
    "    ciudades = [\n",
    "        \"Arica\", \"Iquique\", \"Antofagasta\", \"La Serena\",\n",
    "        \"Valparaiso\", \"Santiago\", \"Concepcion\", \"Temuco\",\n",
    "        \"Puerto Montt\", \"Punta Arenas\"\n",
    "    ]\n",
    "\n",
    "    plataforma = \"Google Hotels\"\n",
    "    integrante = \"bastian-bravo\"\n",
    "    grupo = \"G5_Turismo_Hoteleria\"\n",
    "\n",
    "    for ciudad in ciudades:\n",
    "        url = f\"https://www.google.com/travel/hotels?q=hoteles+en+{ciudad.lower().replace(' ', '+')}+chile\"\n",
    "\n",
    "        print(f\"\\n{'='*50}\")\n",
    "        print(f\"Ciudad: {ciudad}\")\n",
    "        print(f\"{'='*50}\")\n",
    "\n",
    "        driver.get(url)\n",
    "        time.sleep(8)\n",
    "\n",
    "        # Scroll\n",
    "        for _ in range(5):\n",
    "            driver.execute_script(\"window.scrollBy(0, 800);\")\n",
    "            time.sleep(1.5)\n",
    "\n",
    "        # Extraer nombres (h2 que contienen nombres de hoteles)\n",
    "        nombres = []\n",
    "        todos_h2 = driver.find_elements(By.TAG_NAME, \"h2\")\n",
    "        for h2 in todos_h2:\n",
    "            texto = h2.text.strip()\n",
    "            if texto and len(texto) > 5 and not any(x in texto.lower() for x in ['sponsored', 'search', 'filter', 'sort', 'set your dates', 'popular']):\n",
    "                nombres.append(texto)\n",
    "\n",
    "        # Extraer precios\n",
    "        precios = []\n",
    "        elementos_precio = driver.find_elements(By.XPATH, \"//span[contains(text(), '$')]\")\n",
    "        for elem in elementos_precio:\n",
    "            texto = elem.text.strip()\n",
    "            if texto and '$' in texto and len(texto) < 30:\n",
    "                precio = limpiar_precio(texto)\n",
    "                if precio > 0:\n",
    "                    precios.append(precio)\n",
    "\n",
    "        zona = determinar_zona(ciudad)\n",
    "        guardados = 0\n",
    "\n",
    "        for i in range(min(len(nombres), len(precios))):\n",
    "            registro = {\n",
    "                'nombre_hotel': nombres[i],\n",
    "                'precio_noche': precios[i],\n",
    "                'ciudad': ciudad,\n",
    "                'zona_geografica': zona,\n",
    "                'estrellas': 0,\n",
    "                'tipo_alojamiento': 'hotel',\n",
    "                'puntuacion': None,\n",
    "                'fecha_captura': datetime.now(),\n",
    "                'url_origen': url,\n",
    "                'plataforma': plataforma,\n",
    "                'integrante': integrante,\n",
    "                'grupo': grupo\n",
    "            }\n",
    "\n",
    "            # Guardar en MongoDB Atlas\n",
    "            coleccion.update_one(\n",
    "                {\n",
    "                    'nombre_hotel': registro['nombre_hotel'],\n",
    "                    'ciudad': registro['ciudad'],\n",
    "                    'plataforma': plataforma\n",
    "                },\n",
    "                {'$set': registro},\n",
    "                upsert=True\n",
    "            )\n",
    "\n",
    "            datos_finales.append(registro)\n",
    "            guardados += 1\n",
    "\n",
    "        print(f\"  Guardados en {ciudad}: {guardados}\")\n",
    "        time.sleep(3)\n",
    "\n",
    "    driver.quit()\n",
    "    print(f\"\\n{'='*50}\")\n",
    "    print(f\"TOTAL: {len(datos_finales)} registros en MongoDB Atlas\")\n",
    "    print(f\"{'='*50}\")\n",
    "    return datos_finales"
   ]
  },
